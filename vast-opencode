#!/usr/bin/env bash
set -euo pipefail

# vast-opencode — Single-command GPU coding session
# Finds cheapest suitable GPU on Vast.ai, serves Qwen3.5 via vLLM,
# tunnels to localhost, launches OpenCode, and tears everything down on exit.

# ─── Defaults (override via env vars) ────────────────────────────────────────

MODEL="${VAST_MODEL:-Qwen/Qwen3.5-35B-A3B}"
CTX_LEN="${VAST_CTX_LEN:-}"  # auto-selected based on GPU VRAM if not set
MIN_VRAM="${VAST_MIN_VRAM:-60}"
MIN_DISK="${VAST_MIN_DISK:-80}"
MIN_RELIABILITY="${VAST_MIN_RELIABILITY:-0.95}"
MIN_INET="${VAST_MIN_INET:-1000}"
THINKING="${VAST_THINKING:-}"  # empty = prompt user; "on" or "off"
VLLM_IMAGE="${VAST_VLLM_IMAGE:-vllm/vllm-openai:nightly}"  # nightly required for Qwen3.5 until vLLM 0.17.0
READY_TIMEOUT="${VAST_READY_TIMEOUT:-900}"  # 15 minutes
LOCAL_PORT="${VAST_LOCAL_PORT:-8000}"

# ─── State ───────────────────────────────────────────────────────────────────

INSTANCE_ID=""
SSH_TUNNEL_PID=""
OPENCODE_CONFIG_TMP=""
START_TIME=""
OFFER_PRICE=""

# ─── Colors ──────────────────────────────────────────────────────────────────

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

info()  { echo -e "${CYAN}>>>${NC} $*"; }
ok()    { echo -e "${GREEN}>>>${NC} $*"; }
warn()  { echo -e "${YELLOW}>>>${NC} $*"; }
err()   { echo -e "${RED}>>>${NC} $*" >&2; }

# ─── Cleanup / Teardown ─────────────────────────────────────────────────────

CLEANUP_DONE=false

cleanup() {
    # Prevent running twice (Ctrl+C sends INT, then EXIT fires)
    if [[ "$CLEANUP_DONE" == true ]]; then
        return
    fi
    CLEANUP_DONE=true

    local exit_code=$?
    echo ""
    info "Shutting down..."

    # Kill SSH tunnel
    if [[ -n "$SSH_TUNNEL_PID" ]]; then
        kill "$SSH_TUNNEL_PID" 2>/dev/null || true
        wait "$SSH_TUNNEL_PID" 2>/dev/null || true
        ok "SSH tunnel closed"
    fi

    # Destroy Vast.ai instance
    if [[ -n "$INSTANCE_ID" ]]; then
        info "Destroying Vast.ai instance ${INSTANCE_ID}..."
        vastai destroy instance "$INSTANCE_ID" 2>&1 || true
        ok "Instance ${INSTANCE_ID} destroyed — billing stopped"
    fi

    # Clean up temp config
    if [[ -n "$OPENCODE_CONFIG_TMP" && -f "$OPENCODE_CONFIG_TMP" ]]; then
        rm -f "$OPENCODE_CONFIG_TMP"
    fi

    # Session summary
    if [[ -n "$START_TIME" ]]; then
        local elapsed=$(( $(date +%s) - START_TIME ))
        local mins=$(( elapsed / 60 ))
        local secs=$(( elapsed % 60 ))
        echo ""
        info "Session duration: ${mins}m ${secs}s"
        if [[ -n "$OFFER_PRICE" ]]; then
            local cost
            cost=$(printf '%.4f' "$(echo "scale=4; $OFFER_PRICE * $elapsed / 3600" | bc)" 2>/dev/null || echo "??")
            info "Estimated cost: ~\$${cost}"
        fi
    fi

    exit "$exit_code"
}

trap cleanup EXIT INT TERM

# ─── Usage ───────────────────────────────────────────────────────────────────

usage() {
    cat <<'EOF'
Usage: vast-opencode [OPTIONS]

Spin up a GPU on Vast.ai, serve a model via vLLM, and launch OpenCode.
Everything is torn down automatically when you quit.

Options:
  -m, --model MODEL      Model to serve (default: Qwen/Qwen3.5-35B-A3B)
  -c, --ctx-len N        Max context length (auto: 128K@48GB, 256K@80GB+)
  -v, --vram N           Minimum GPU VRAM in GB (default: 60)
  -p, --port N           Local port for tunnel (default: 8000)
  --thinking             Enable thinking/reasoning mode (default: prompted)
  --no-thinking          Disable thinking/reasoning mode
  -y, --yes              Skip confirmation prompt (uses thinking=on)
  -h, --help             Show this help

Environment variables:
  VAST_MODEL             Same as --model
  VAST_CTX_LEN           Same as --ctx-len (overrides auto-detection)
  VAST_MIN_VRAM          Same as --vram
  VAST_MIN_DISK          Min disk space in GB (default: 80)
  VAST_MIN_RELIABILITY   Min reliability score (default: 0.95)
  VAST_MIN_INET          Min download bandwidth Mbps (default: 1000)
  VAST_VLLM_IMAGE        Docker image (default: vllm/vllm-openai:nightly)
  VAST_READY_TIMEOUT     Seconds to wait for model ready (default: 900)
  VAST_LOCAL_PORT        Same as --port
  VAST_THINKING          "on" or "off" — same as --thinking/--no-thinking
  HF_TOKEN               HuggingFace token (optional, for gated models)
EOF
    exit 0
}

# ─── Parse Args ──────────────────────────────────────────────────────────────

AUTO_YES=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        -m|--model)    MODEL="$2"; shift 2 ;;
        -c|--ctx-len)  CTX_LEN="$2"; shift 2 ;;
        -v|--vram)     MIN_VRAM="$2"; shift 2 ;;
        -p|--port)     LOCAL_PORT="$2"; shift 2 ;;
        --thinking)    THINKING="on"; shift ;;
        --no-thinking) THINKING="off"; shift ;;
        -y|--yes)      AUTO_YES=true; shift ;;
        -h|--help)     usage ;;
        *)             err "Unknown option: $1"; usage ;;
    esac
done

# ─── Phase 1: Preflight Checks ──────────────────────────────────────────────

info "Checking prerequisites..."

# jq
if ! command -v jq &>/dev/null; then
    warn "jq not found, installing..."
    sudo apt-get update -qq && sudo apt-get install -y -qq jq
fi

# vastai CLI
if ! command -v vastai &>/dev/null; then
    warn "Vast.ai CLI not found, installing..."
    if command -v pipx &>/dev/null; then
        pipx install vastai
    else
        pip install --break-system-packages vastai 2>/dev/null \
            || pip install --user vastai
    fi
    # Ensure pipx/user bin is in PATH for this session
    export PATH="$HOME/.local/bin:$PATH"
    if ! command -v vastai &>/dev/null; then
        err "Vast.ai CLI installation failed. Install manually: pipx install vastai"
        exit 1
    fi
fi

# opencode
if ! command -v opencode &>/dev/null; then
    warn "OpenCode not found, installing..."
    curl -fsSL https://raw.githubusercontent.com/opencode-ai/opencode/refs/heads/main/install | bash
    # Add to PATH for this session if installed to ~/.local/bin or similar
    export PATH="$HOME/.local/bin:$HOME/.opencode/bin:$PATH"
    if ! command -v opencode &>/dev/null; then
        err "OpenCode installation failed. Install manually: https://opencode.ai/download"
        exit 1
    fi
fi

# Load .env from home directory if it exists
ENV_FILE="$HOME/.vast-opencode.env"
if [[ -f "$ENV_FILE" ]]; then
    # Source it, but only export known keys (don't blindly eval)
    while IFS='=' read -r key value; do
        # Skip comments and blank lines
        [[ -z "$key" || "$key" =~ ^# ]] && continue
        # Strip surrounding quotes from value
        value="${value#\"}" ; value="${value%\"}"
        value="${value#\'}" ; value="${value%\'}"
        case "$key" in
            VAST_API_KEY)  export VAST_API_KEY="$value" ;;
            HF_TOKEN)      export HF_TOKEN="$value" ;;
        esac
    done < "$ENV_FILE"
    ok "Loaded keys from ${ENV_FILE}"
fi

SAVE_KEYS=false

# Vast.ai API key
if [[ ! -f "$HOME/.vast_api_key" ]]; then
    if [[ -n "${VAST_API_KEY:-}" ]]; then
        vastai set api-key "$VAST_API_KEY"
    else
        warn "No Vast.ai API key found."
        echo -n "Enter your Vast.ai API key (from https://cloud.vast.ai/cli/): "
        read -r VAST_API_KEY
        if [[ -z "$VAST_API_KEY" ]]; then
            err "API key required."
            exit 1
        fi
        vastai set api-key "$VAST_API_KEY"
        SAVE_KEYS=true
    fi
fi

# HuggingFace token (optional — needed only for gated models)
if [[ -z "${HF_TOKEN:-}" ]]; then
    info "HF_TOKEN not set. The default model (Qwen3.5) is public and doesn't need one."
    echo -n "Enter a HuggingFace token (press Enter to skip): "
    read -r HF_TOKEN
    if [[ -n "$HF_TOKEN" ]]; then
        export HF_TOKEN
        SAVE_KEYS=true
    fi
fi

# Save keys to .env for next time if any were entered interactively
if [[ "$SAVE_KEYS" == true ]]; then
    echo -n "Save keys to ${ENV_FILE} for next time? [Y/n] "
    read -r save_choice
    if [[ ! "$save_choice" =~ ^[Nn] ]]; then
        {
            echo "# vast-opencode credentials"
            [[ -n "${VAST_API_KEY:-}" ]] && echo "VAST_API_KEY=${VAST_API_KEY}"
            [[ -n "${HF_TOKEN:-}" ]] && echo "HF_TOKEN=${HF_TOKEN}"
        } > "$ENV_FILE"
        chmod 600 "$ENV_FILE"
        ok "Keys saved to ${ENV_FILE}"
    fi
fi

ok "All prerequisites satisfied"

# ─── Helper: normalize VRAM to GB ────────────────────────────────────────────
# Vast.ai raw JSON returns gpu_ram in MB; convert to GB for display/logic
vram_to_gb() {
    local raw="$1"
    local int_raw=$(echo "$raw" | cut -d. -f1)
    if (( int_raw > 1000 )); then
        echo $(( int_raw / 1024 ))
    else
        echo "$int_raw"
    fi
}

# ─── Phase 2: Find GPU Offers ────────────────────────────────────────────────

MAX_OFFERS="${VAST_MAX_OFFERS:-10}"

# Note: search filter uses GB, but raw JSON returns MB — Vast.ai converts internally
info "Searching for GPUs (>=${MIN_VRAM}GB VRAM, verified, reliable)..."

SEARCH_RESULTS=$(vastai search offers \
    "gpu_ram>=${MIN_VRAM} reliability>${MIN_RELIABILITY} inet_down>=${MIN_INET} disk_space>=${MIN_DISK} rentable=true verified=true" \
    -o 'dph_total' --raw 2>/dev/null) || {
    err "Failed to search Vast.ai offers. Check your API key and network."
    exit 1
}

# Get top N offers sorted by price
NUM_AVAILABLE=$(echo "$SEARCH_RESULTS" | jq 'length')

if [[ "$NUM_AVAILABLE" -eq 0 || "$NUM_AVAILABLE" == "null" ]]; then
    err "No suitable GPU offers found. Try relaxing filters (lower VRAM, reliability, etc.)"
    exit 1
fi

SHOW_COUNT=$(( NUM_AVAILABLE < MAX_OFFERS ? NUM_AVAILABLE : MAX_OFFERS ))

echo ""
echo -e "${BOLD}Available GPU offers (sorted by price):${NC}"
echo ""
printf "  ${BOLD}%-4s  %-22s  %-6s  %-10s  %-8s  %-6s  %s${NC}\n" \
    "#" "GPU" "VRAM" "Price" "DL Mbps" "Rel." "Location"
echo "  ──────────────────────────────────────────────────────────────────────────────"

for i in $(seq 0 $(( SHOW_COUNT - 1 ))); do
    ITEM=$(echo "$SEARCH_RESULTS" | jq -r ".[$i]")
    i_gpu=$(echo "$ITEM" | jq -r '.gpu_name')
    i_num=$(echo "$ITEM" | jq -r '.num_gpus')
    i_ram_raw=$(echo "$ITEM" | jq -r '.gpu_ram | floor')
    i_ram=$(vram_to_gb "$i_ram_raw")
    i_price=$(echo "$ITEM" | jq -r '.dph_total | . * 1000 | round / 1000')
    i_inet=$(echo "$ITEM" | jq -r '.inet_down | floor')
    i_rel=$(echo "$ITEM" | jq -r '(.reliability * 100) | floor | tostring + "%"')
    i_loc=$(echo "$ITEM" | jq -r '.geolocation // "?"')

    gpu_label="${i_num}x ${i_gpu}"

    printf "  ${GREEN}%-4s${NC}  %-22s  %-4sGB  \$%-9s  %-8s  %-6s  %s\n" \
        "$((i + 1))" "$gpu_label" "$i_ram" "$i_price" "$i_inet" "$i_rel" "$i_loc"
done

echo ""

if [[ "$AUTO_YES" == true ]]; then
    SELECTION=1
else
    echo -n "Select an offer [1-${SHOW_COUNT}] (or 'q' to quit): "
    read -r SELECTION
    if [[ "$SELECTION" == "q" || "$SELECTION" == "Q" ]]; then
        info "Aborted."
        INSTANCE_ID=""
        exit 0
    fi
    if ! [[ "$SELECTION" =~ ^[0-9]+$ ]] || (( SELECTION < 1 || SELECTION > SHOW_COUNT )); then
        err "Invalid selection: $SELECTION"
        exit 1
    fi
fi

# Extract the chosen offer
IDX=$(( SELECTION - 1 ))
OFFER=$(echo "$SEARCH_RESULTS" | jq -r ".[$IDX]")
OFFER_ID=$(echo "$OFFER" | jq -r '.id')
OFFER_GPU=$(echo "$OFFER" | jq -r '.gpu_name')
OFFER_GPU_RAM_RAW=$(echo "$OFFER" | jq -r '.gpu_ram')
OFFER_GPU_RAM=$(vram_to_gb "$OFFER_GPU_RAM_RAW")
OFFER_NUM_GPUS=$(echo "$OFFER" | jq -r '.num_gpus')
OFFER_PRICE=$(echo "$OFFER" | jq -r '.dph_total')
OFFER_LOCATION=$(echo "$OFFER" | jq -r '.geolocation // "Unknown"')

ok "Selected: ${OFFER_NUM_GPUS}x ${OFFER_GPU} (${OFFER_GPU_RAM}GB) @ \$${OFFER_PRICE}/hr — ${OFFER_LOCATION}"

# Auto-select context length based on GPU VRAM if not explicitly set
# FP8 weights ~35GB, remainder goes to KV cache + overhead
if [[ -z "$CTX_LEN" ]]; then
    VRAM="$OFFER_GPU_RAM"
    if (( VRAM >= 80 )); then
        CTX_LEN=262144   # 256K — full native context
    elif (( VRAM >= 60 )); then
        CTX_LEN=131072   # 128K — safe on 60-79GB with FP8
    else
        CTX_LEN=65536    # 64K — fallback
    fi
    info "Auto-selected context length: ${CTX_LEN} tokens (for ${VRAM}GB VRAM)"
fi

# ─── Thinking Mode ───────────────────────────────────────────────────────────

if [[ -z "$THINKING" ]]; then
    if [[ "$AUTO_YES" == true ]]; then
        THINKING="on"
    else
        echo ""
        echo -e "${BOLD}Thinking mode:${NC}"
        echo -e "  The model can \"think\" before responding — reasoning step-by-step"
        echo -e "  internally before giving its answer. This improves quality on"
        echo -e "  complex tasks but uses more tokens and is slower."
        echo ""
        echo -e "  ${GREEN}on${NC}   Better quality, uses more context, slower responses"
        echo -e "  ${YELLOW}off${NC}  Faster responses, uses less context, still capable"
        echo ""
        echo -n "Enable thinking mode? [Y/n] "
        read -r think_choice
        if [[ "$think_choice" =~ ^[Nn] ]]; then
            THINKING="off"
        else
            THINKING="on"
        fi
    fi
fi

if [[ "$THINKING" == "on" ]]; then
    ok "Thinking mode: ON"
    THINKING_ENABLED=true
else
    ok "Thinking mode: OFF"
    THINKING_ENABLED=false
fi

# ─── Phase 3: Provision Instance ─────────────────────────────────────────────

info "Provisioning instance (image: ${VLLM_IMAGE})..."

# Build vLLM args for onstart
VLLM_EXTRA_ARGS="--reasoning-parser qwen3"
if [[ "$THINKING_ENABLED" == false ]]; then
    VLLM_EXTRA_ARGS="${VLLM_EXTRA_ARGS} --default-chat-template-kwargs '{\"enable_thinking\": false}'"
fi

ONSTART_CMD=$(cat <<EOSCRIPT
#!/bin/bash
set -e
env | grep _ >> /etc/environment
echo "Starting vLLM server..."
python3 -m vllm.entrypoints.openai.api_server \
    --model ${MODEL} \
    --port 8000 \
    --trust-remote-code \
    --max-model-len ${CTX_LEN} \
    --quantization fp8 \
    ${VLLM_EXTRA_ARGS} \
    --host 0.0.0.0 2>&1 | tee /var/log/vllm.log &
echo "vLLM server started in background"
EOSCRIPT
)

# Build env flags — only include HF token if provided
ENV_FLAGS="-p 8000:8000 -p 22:22"
if [[ -n "${HF_TOKEN:-}" ]]; then
    ENV_FLAGS="-e HF_TOKEN=${HF_TOKEN} -e HUGGING_FACE_HUB_TOKEN=${HF_TOKEN} ${ENV_FLAGS}"
fi

CREATE_OUTPUT=$(vastai create instance "$OFFER_ID" \
    --image "$VLLM_IMAGE" \
    --disk "$MIN_DISK" \
    --env "$ENV_FLAGS" \
    --onstart-cmd "$ONSTART_CMD" \
    --ssh \
    --direct \
    2>&1) || {
    err "Failed to create instance: $CREATE_OUTPUT"
    exit 1
}

# Extract instance ID from output (format: "Started. {'new_contract': 12345678}")
INSTANCE_ID=$(echo "$CREATE_OUTPUT" | grep -oP '\d{6,}' | head -1)

if [[ -z "$INSTANCE_ID" ]]; then
    err "Could not parse instance ID from: $CREATE_OUTPUT"
    exit 1
fi

START_TIME=$(date +%s)
ok "Instance ${INSTANCE_ID} created"

# ─── Phase 4: Wait for Instance & Model Ready ───────────────────────────────

info "Waiting for instance to start (this may take a few minutes)..."

DEADLINE=$(( $(date +%s) + READY_TIMEOUT ))
SSH_HOST=""
SSH_PORT=""

# Wait for instance running
while true; do
    if [[ $(date +%s) -gt $DEADLINE ]]; then
        err "Timed out waiting for instance to start."
        err "Check logs: vastai logs ${INSTANCE_ID}"
        exit 1
    fi

    STATUS_JSON=$(vastai show instance "$INSTANCE_ID" --raw 2>/dev/null || echo "{}")
    ACTUAL_STATUS=$(echo "$STATUS_JSON" | jq -r '.actual_status // "unknown"')

    if [[ "$ACTUAL_STATUS" == "running" ]]; then
        # With --direct, use public IP + direct port mapping (not the ssh proxy)
        SSH_HOST=$(echo "$STATUS_JSON" | jq -r '.public_ipaddr // empty')
        SSH_PORT=$(echo "$STATUS_JSON" | jq -r '.ports["22/tcp"][0].HostPort // empty')
        VLLM_DIRECT_PORT=$(echo "$STATUS_JSON" | jq -r '.ports["8000/tcp"][0].HostPort // empty')

        # Fallback to ssh proxy if direct ports not available
        if [[ -z "$SSH_HOST" || -z "$SSH_PORT" ]]; then
            SSH_HOST=$(echo "$STATUS_JSON" | jq -r '.ssh_host // empty')
            SSH_PORT=$(echo "$STATUS_JSON" | jq -r '.ssh_port // empty')
        fi

        if [[ -n "$SSH_HOST" && -n "$SSH_PORT" ]]; then
            ok "Instance running at ${SSH_HOST}:${SSH_PORT}"
            break
        fi
    fi

    echo -n "."
    sleep 15
done

# Set up SSH tunnel (instance may need time before SSH is accepting connections)
info "Opening SSH tunnel (localhost:${LOCAL_PORT} -> instance:8000)..."

# Common SSH options: accept new host keys automatically, no interactive prompts
SSH_OPTS=(-o StrictHostKeyChecking=accept-new -o UserKnownHostsFile=/dev/null -o ConnectTimeout=10 -o LogLevel=ERROR)

# Wait until SSH port is actually accepting connections
SSH_RETRIES=18  # up to ~3 minutes of retrying
SSH_CONNECTED=false

for attempt in $(seq 1 $SSH_RETRIES); do
    if [[ $(date +%s) -gt $DEADLINE ]]; then
        err "Timed out waiting for SSH"
        exit 1
    fi

    # Test SSH connectivity (accept-new auto-accepts host key on first connect)
    SSH_ERR=$(ssh "${SSH_OPTS[@]}" -p "$SSH_PORT" "root@${SSH_HOST}" echo ok 2>&1) && {
        SSH_CONNECTED=true
        break
    }

    # Show what's happening on first and every 3rd attempt
    if (( attempt == 1 )); then
        warn "SSH not ready yet: ${SSH_ERR##*$'\n'}"
        info "Retrying (attempt ${attempt}/${SSH_RETRIES})..."
    elif (( attempt % 3 == 0 )); then
        info "Still waiting for SSH (attempt ${attempt}/${SSH_RETRIES})..."
    fi

    echo -n "."
    sleep 10
done

if [[ "$SSH_CONNECTED" != true ]]; then
    err "Could not connect to instance via SSH after ${SSH_RETRIES} attempts"
    err "Last error: ${SSH_ERR:-unknown}"
    err "Check that your SSH key is added at https://cloud.vast.ai/account/"
    exit 1
fi

ok "SSH connection verified"

# Now establish the tunnel
ssh "${SSH_OPTS[@]}" -o ServerAliveInterval=30 -o ExitOnForwardFailure=yes \
    -f -N -L "${LOCAL_PORT}:localhost:8000" \
    -p "$SSH_PORT" "root@${SSH_HOST}" 2>&1 || {
    err "Failed to open SSH tunnel"
    exit 1
}

# Find the tunnel process
sleep 1
SSH_TUNNEL_PID=$(pgrep -f "ssh.*-N.*-L ${LOCAL_PORT}:localhost:8000" | head -1)

if [[ -z "$SSH_TUNNEL_PID" ]]; then
    err "SSH tunnel process not found"
    exit 1
fi

ok "SSH tunnel established (PID: ${SSH_TUNNEL_PID})"

# Wait for vLLM to be ready
info "Waiting for vLLM to load model (this can take several minutes)..."
info "Checking instance logs periodically..."

VLLM_POLL=0
while true; do
    if [[ $(date +%s) -gt $DEADLINE ]]; then
        err "Timed out waiting for vLLM."
        warn "Fetching instance logs:"
        vastai logs "$INSTANCE_ID" --tail 80 2>/dev/null || true
        echo ""
        warn "You can also check via: ssh -p ${SSH_PORT} root@${SSH_HOST} cat /var/log/vllm.log"
        exit 1
    fi

    if curl -sf "http://localhost:${LOCAL_PORT}/v1/models" &>/dev/null; then
        echo ""
        ok "vLLM is ready! Model loaded."
        break
    fi

    VLLM_POLL=$(( VLLM_POLL + 1 ))

    # Every 30 seconds (~3 polls), show latest log line from the instance
    if (( VLLM_POLL % 3 == 0 )); then
        LAST_LOG=$(ssh "${SSH_OPTS[@]}" \
            -p "$SSH_PORT" "root@${SSH_HOST}" \
            "tail -1 /var/log/vllm.log 2>/dev/null || vastai logs $INSTANCE_ID --tail 1 2>/dev/null" 2>/dev/null || true)
        if [[ -n "$LAST_LOG" ]]; then
            echo ""
            info "vLLM: ${LAST_LOG}"
        fi
    fi

    echo -n "."
    sleep 10
done

# ─── Phase 5: Configure & Launch OpenCode ────────────────────────────────────

info "Launching OpenCode..."

MODEL_ID=$(curl -sf "http://localhost:${LOCAL_PORT}/v1/models" | jq -r '.data[0].id // empty')
if [[ -z "$MODEL_ID" ]]; then
    MODEL_ID="$MODEL"
fi

OPENCODE_CONFIG_TMP=$(mktemp /tmp/opencode-vast-XXXXXX.json)
cat > "$OPENCODE_CONFIG_TMP" <<EOCONF
{
  "\$schema": "https://opencode.ai/config.json",
  "provider": {
    "vast": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Vast.ai vLLM",
      "options": {
        "baseURL": "http://localhost:${LOCAL_PORT}/v1"
      },
      "models": {
        "${MODEL_ID}": {
          "name": "Qwen3.5 A3B (Vast.ai)",
          "limit": { "context": ${CTX_LEN}, "output": 32000 }
        }
      }
    }
  },
  "model": "vast/${MODEL_ID}",
  "small_model": "vast/${MODEL_ID}"
}
EOCONF

echo ""
echo -e "${BOLD}═══════════════════════════════════════════════════════${NC}"
OFFER_PRICE_FMT=$(printf '%.2f' "$OFFER_PRICE" 2>/dev/null || echo "$OFFER_PRICE")
echo -e "${GREEN}  GPU session active — ${OFFER_NUM_GPUS}x ${OFFER_GPU} (${OFFER_GPU_RAM}GB) @ \$${OFFER_PRICE_FMT}/hr${NC}"
echo -e "${GREEN}  Model: ${MODEL_ID}${NC}"
echo -e "${GREEN}  Context: ${CTX_LEN} tokens${NC}"
echo -e "${GREEN}  Thinking: ${THINKING^^}${NC}"
echo -e "${BOLD}  Quit OpenCode to automatically destroy the instance${NC}"
echo -e "${BOLD}═══════════════════════════════════════════════════════${NC}"
echo ""

# Launch opencode with the temp config
OPENCODE_CONFIG="$OPENCODE_CONFIG_TMP" \
OPENAI_API_KEY="sk-local" \
    opencode || true

# When opencode exits, the trap fires and cleans everything up
